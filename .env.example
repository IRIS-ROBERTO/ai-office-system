# ============================================================
# AI OFFICE SYSTEM — Environment Variables
# Copie este arquivo para .env e preencha os valores
# ============================================================

# === Senior AI Model (OpenRouter) ===
# Acesse: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...
SENIOR_MODEL=anthropic/claude-sonnet-4-6

# === Supabase ===
# Acesse: Project Settings → API no dashboard Supabase
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...

# === GitHub (para agentes commitarem) ===
# Crie em: github.com/settings/tokens/new
# Permissões necessárias: repo (full), workflow
GITHUB_TOKEN=ghp_...
GITHUB_USERNAME=IRIS-ROBERTO
# Deixe vazio para usar conta pessoal, ou preencha com org
GITHUB_DEFAULT_ORG=

# === Redis (local via Docker) ===
REDIS_URL=redis://localhost:6379
# true keeps local development running with in-memory fakeredis when Redis is down.
# Set false for premium/staging/production so the system fails instead of losing event history.
EVENTBUS_ALLOW_FAKE_REDIS=true

# === Ollama (modelos locais) ===
OLLAMA_BASE_URL=http://localhost:11434
LOCAL_MODEL_CODE=qwen2.5-coder:32b
LOCAL_MODEL_GENERAL=llama3.3:70b
LOCAL_MODEL_REASONING=deepseek-r1:32b

# === PicoClaw MCP / plugin bridge ===
PICOCLAW_HOST=http://127.0.0.1:18790
PICOCLAW_ENABLED=true
# Production posture requires PicoClaw online because it is the local MCP/plugin bridge.
PICOCLAW_REQUIRED=true

# === API Server ===
API_HOST=0.0.0.0
API_PORT=8000

# === Performance ===
MAX_CONCURRENT_AGENTS=12
QUALITY_GATE_ENABLED=true
MAX_RETRIES_PER_SUBTASK=3
ANIMATION_QUEUE_BUFFER_MS=500
